# ── Feelio — Railway Environment Variables Template ──────────────────────────
# Copy these into Railway → Project → Variables
# Lines prefixed with # are comments / optional vars

# Core Django
SECRET_KEY=your-strong-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-app.up.railway.app,your-custom-domain.com

# Railway injects this automatically when you add a Postgres plugin.
# You do NOT need to set this manually — shown here for reference only.
# DATABASE_URL=postgresql://user:password@host:port/dbname

# CSRF — add your Railway domain and any custom domain (comma-separated)
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app,https://your-custom-domain.com

# Email (optional — leave as console for now, or use SendGrid / Mailgun)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@feelio.lk
